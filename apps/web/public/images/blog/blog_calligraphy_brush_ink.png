<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1C1C1E;stop-opacity:0.12"/>
      <stop offset="100%" style="stop-color:#1C1C1E;stop-opacity:0.04"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <text x="400" y="280" font-family="serif" font-size="72" fill="#1C1C1E" text-anchor="middle" opacity="0.25">書</text>
  <text x="400" y="360" font-family="sans-serif" font-size="18" fill="#1C1C1E" text-anchor="middle" opacity="0.4">Chinese Calligraphy</text>
</svg>
